10.3 Code Example: Azure Storage HTTPS Enforcement

# function_storage_enable_https.py
import azure.functions as func
import logging
from azure.identity import DefaultAzureCredential
from azure.mgmt.storage import StorageManagementClient

def main(event: func.EventGridEvent):
    """Auto-remediation: Enable HTTPS-only on storage accounts"""
    
    subscription_id = os.environ.get("AZURE_SUBSCRIPTION_ID")
    credential = DefaultAzureCredential()
    storage_client = StorageManagementClient(credential, subscription_id)
    
    # Get storage account from event
    storage_account_name = event.data.get("storage_account_name")
    resource_group = event.data.get("resource_group")
    
    # Enable HTTPS-only
    storage_client.storage_accounts.update(
        resource_group_name=resource_group,
        account_name=storage_account_name,
        parameters={
            "properties": {
                "enable_https_traffic_only": True
            }
        }
    )
    
    logging.info(f"✅ HTTPS-only enabled for {storage_account_name}")
    
    # Verify the fix
    account = storage_client.storage_accounts.get_properties(
        resource_group_name=resource_group,
        account_name=storage_account_name
    )
    
    if account.enable_https_traffic_only:
        logging.info(f"✅ Verification passed for {storage_account_name}")
    else:
        logging.error(f"❌ Verification failed for {storage_account_name}")

